# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/omnes_crm

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://crm.omnesmedia.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOGIN_RATE_LIMIT_MAX=10
